#!/bin/sh

# Copyright (C) 2006 OpenWrt.org
# Copyright 2022-2025 sirpdboy <herboy2008@gmail.com>

NAME=timecontrol
IDLIST="/var/$NAME.idlist"
TIMECONTROL="/usr/bin/timecontrol"

[ -x "$TIMECONTROL" ] || TIMECONTROL="timecontrol"

config_t_get() {
    local section=$1
    local option=$2
    local index=${3:-0}
    local default=$4
    local ret

    ret=$(uci -q get "${NAME}.@${section}[${index}].${option}")
    echo "${ret:-$default}"
}

is_enabled() {
    [ "$(uci -q get "$NAME.@timecontrol[0].enabled" 2>/dev/null)" = "1" ]
}

ensure_idlist() {
    [ -f "$IDLIST" ] || : > "$IDLIST"
}

id_in_list() {
    grep -Fxq "!$1!" "$IDLIST" 2>/dev/null
}

get_enabled_device_ids() {
    is_enabled || return 0

    uci show "$NAME" 2>/dev/null |
        sed -n "s/^${NAME}\.@device\[\([0-9][0-9]*\)\]\.enable='1'$/\1/p"
}

get_tracked_device_ids() {
    [ -f "$IDLIST" ] || return 0
    sed -n 's/^!\([0-9][0-9]*\)!$/\1/p' "$IDLIST"
}

id_in_ids() {
    local needle
    local ids
    local id

    needle=$1
    ids=$2

    for id in $ids; do
        [ "$id" = "$needle" ] && return 0
    done

    return 1
}

valid_time() {
    case "$1" in
        [01][0-9]:[0-5][0-9]|2[0-3]:[0-5][0-9])
            return 0
            ;;
    esac

    return 1
}

time_to_minutes() {
    local hour
    local minute

    hour=${1%%:*}
    minute=${1##*:}

    hour=${hour#0}
    minute=${minute#0}

    [ -n "$hour" ] || hour=0
    [ -n "$minute" ] || minute=0

    echo $((hour * 60 + minute))
}

is_time_in_range() {
    local start_time
    local end_time
    local current_time
    local start_min
    local end_min
    local current_min

    start_time=$1
    end_time=$2

    valid_time "$start_time" || return 1
    valid_time "$end_time" || return 1

    current_time=$(date +%H:%M)
    start_min=$(time_to_minutes "$start_time")
    end_min=$(time_to_minutes "$end_time")
    current_min=$(time_to_minutes "$current_time")

    [ "$start_min" -lt "$end_min" ] || return 1
    [ "$current_min" -ge "$start_min" ] && [ "$current_min" -lt "$end_min" ]
}

is_weekday_in_range() {
    local weekdays
    local current_weekday
    local weekday

    weekdays=${1:-0}
    current_weekday=$(date +%u)

    for weekday in $(printf '%s\n' "$weekdays" | tr ',' ' '); do
        [ "$weekday" = "0" ] && return 0
        [ "$weekday" = "$current_weekday" ] && return 0
    done

    return 1
}

should_block_device() {
    local id
    local start_time
    local end_time
    local weekdays

    id=$1

    start_time=$(config_t_get device timestart "$id" "00:00")
    end_time=$(config_t_get device timeend "$id" "00:00")
    weekdays=$(config_t_get device week "$id" "0")

    is_weekday_in_range "$weekdays" && is_time_in_range "$start_time" "$end_time"
}

tracked_ids_need_rebuild() {
    local enabled_ids
    local id

    enabled_ids=$1

    for id in $(get_tracked_device_ids); do
        id_in_ids "$id" "$enabled_ids" || return 0
    done

    return 1
}

run_timecontrol() {
    "$TIMECONTROL" "$@" >/dev/null 2>&1
}

get_config_snapshot() {
    uci -q show "$NAME" 2>/dev/null
}

process_devices() {
    if is_enabled; then
        run_timecontrol sync
    else
        run_timecontrol stop
    fi
}

ensure_idlist
last_config=$(get_config_snapshot)
process_devices

while :; do
    current_config=$(get_config_snapshot)

    if [ "$current_config" != "$last_config" ]; then
        process_devices && last_config="$current_config"
    else
        process_devices
    fi

    sleep 60
done
