msgid "Users can limit their internet usage time through MAC and IP, with available IP ranges such as 192.168.10.100-200,Managed devices will be unable to access the soft router's administrative interface!"
msgstr "可以通过 MAC、IP 限制用户上网时间，可用 IP 范围如：192.168.10.100-200，被管控的机器将无法连接上软路由后台！"

msgid "Set viewing or rest time to 0 to block for the whole start and stop time range. When both are greater than 0, the viewing and rest loop runs only inside that range; outside it, no control is applied."
msgstr "观看时间或休息时间设置为 0 时，在起控和停控时间段内整段禁止；两者都大于 0 时，只在该时间段内执行观看和休息循环，超出时间段不执行控制。"

msgid "IP/MAC"
msgstr "IP/MAC"

msgid "IP/MAC required"
msgstr "请填写 IP/MAC"

msgid "MAC address must use colon-separated format"
msgstr "MAC 地址必须使用冒号分隔格式，如 aa:bb:cc:dd:ee:ff"

msgid "Please enter a valid IPv4, CIDR, IP range (192.168.10.100-200), or MAC address"
msgstr "请输入有效的 IPv4、CIDR、IP 段（192.168.10.100-200）或 MAC 地址"

msgid "Comment"
msgstr "备注"

msgid "Start control time"
msgstr "起控时间"

msgid "Stop control time"
msgstr "停控时间"

msgid "Viewing time(minute)"
msgstr "观看时间(分)"

msgid "Rest time(minute)"
msgstr "休息时间(分)"

msgid "Please enter a non-negative integer"
msgstr "请输入大于等于 0 的整数"

msgid "Please enter time in HH:MM format"
msgstr "请输入 HH:MM 格式的时间"

msgid "Start control time must be earlier than stop control time"
msgstr "起控时间必须早于停控时间"

msgid "Please enter 0 or weekdays from 1 to 7 separated by commas"
msgstr "请输入 0 或用英文逗号分隔的 1 到 7"

