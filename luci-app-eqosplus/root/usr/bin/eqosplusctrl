#!/bin/sh

# Copyright (C) 2006 OpenWrt.org
# Copyright 2022-2025 sirpdboy <herboy2008@gmail.com>
NAME=eqosplus
IDLIST="/var/$NAME.idlist"
TMPID="/var/$NAME.tmpid"

is_enabled() {
	[ "$(uci -q get "$NAME.@eqosplus[0].enabled" 2>/dev/null)" = "1" ]
}

get_enabled_ids() {
	is_enabled || return 0

	uci show "$NAME" 2>/dev/null |
		sed -n "s/^${NAME}\.@device\[\([0-9][0-9]*\)\]\.enable='1'$/\1/p"
}

valid_time() {
	case "$1" in
		[01][0-9]:[0-5][0-9]|2[0-3]:[0-5][0-9])
			return 0
			;;
	esac

	return 1
}

time_to_minutes() {
	tm=$1

	valid_time "$tm" || return 1

	hour=${tm%:*}
	minute=${tm#*:}
	hour=${hour#0}
	hour=${hour#0}
	minute=${minute#0}
	minute=${minute#0}
	[ -n "$hour" ] || hour=0
	[ -n "$minute" ] || minute=0
	[ "$hour" -le 23 ] || return 1

	echo $((hour * 60 + minute))
}

check_time() {
	start_min=$(time_to_minutes "$1") || return 1
	end_min=$(time_to_minutes "$2") || return 1
	current_min=$(time_to_minutes "$(date +%H:%M)") || return 1

	# Same-day windows only; equal or reversed windows are inactive.
	[ "$start_min" -lt "$end_min" ] || return 1

	[ "$current_min" -ge "$start_min" ] && [ "$current_min" -lt "$end_min" ]
}

check_list() {
	i=$1
	day_match=0
	start_time=$(uci -q get "$NAME.@device[$i].timestart" 2>/dev/null)
	end_time=$(uci -q get "$NAME.@device[$i].timeend" 2>/dev/null)
	wweek=$(uci -q get "$NAME.@device[$i].week" 2>/dev/null)
	current_weekday=$(date +%u)

	[ -n "$wweek" ] || wweek=0

	for ww in $(echo "$wweek" | tr ',' ' '); do
		if [ "$ww" = "0" ] || [ "$current_weekday" = "$ww" ]; then
			day_match=1
			break
		fi
	done

	[ "$day_match" -eq 1 ] || return 1

	if [ -n "$start_time" ] && [ -n "$end_time" ]; then
		check_time "$start_time" "$end_time" || return 1
	fi

	return 0
}

ensure_idlist() {
	[ -f "$IDLIST" ] || : > "$IDLIST"
}

id_is_tracked() {
	grep -qxF "!$1!" "$IDLIST" 2>/dev/null
}

mark_id_tracked() {
	id_is_tracked "$1" || echo "!$1!" >> "$IDLIST"
	sort -u "$IDLIST" > "$TMPID" && mv "$TMPID" "$IDLIST"
}

unmark_id_tracked() {
	sed "/^!$1!$/d" "$IDLIST" > "$TMPID" && mv "$TMPID" "$IDLIST"
}

remove_stale_ids() {
	enabled_ids=" $1 "

	for list in $(sed -n 's/^!\([0-9][0-9]*\)!$/\1/p' "$IDLIST" 2>/dev/null); do
		case "$enabled_ids" in
			*" $list "*) ;;
			*)
				eqosplus del "$list"
				unmark_id_tracked "$list"
			;;
		esac
	done
}

idlistusr() {
	ensure_idlist
	idlist=$(get_enabled_ids | tr '\n' ' ')

	for list in $idlist; do
		if check_list "$list"; then
			if ! id_is_tracked "$list"; then
				eqosplus add "$list"
				mark_id_tracked "$list"
			fi
		else
			if id_is_tracked "$list"; then
				eqosplus del "$list"
				unmark_id_tracked "$list"
			fi
		fi
	done

	remove_stale_ids "$idlist"
}


while :; do
	sleep 30
	idlistusr
	sleep 30
done
